PORT=3000
STORAGE_PROVIDER=SQLITE
# For free hosted DB, set STORAGE_PROVIDER=SUPABASE and fill these:
SUPABASE_URL=
# You can use SERVICE_ROLE, PUBLISHABLE, ANON, or SUPABASE_KEY.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_ANON_KEY=
SESSION_SECRET=change-this-secret
ADMIN_EMAIL=admin@preloved.local
ADMIN_PASSWORD=Admin1234!

# Optional SMTP config for emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
# Use your real mailbox and SMTP password/app-password.
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password-or-app-password
FROM_EMAIL=your-email@example.com
FROM_NAME=Pre-loved by Lhota
# Keep true in production unless your provider requires otherwise.
SMTP_REJECT_UNAUTHORIZED=true

# Optional: hours before pending-order reminder email is sent to admin
UNPROCESSED_ORDER_REMINDER_HOURS=24

# Optional: AI product-name suggestion from uploaded image (Admin Links tab)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
