<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <% if (typeof meta !== "undefined" && meta) { %>
      <% if (meta.description) { %><meta name="description" content="<%= meta.description %>" /><% } %>
      <% if (meta.canonicalUrl) { %><link rel="canonical" href="<%= meta.canonicalUrl %>" /><% } %>
      <% if (meta.ogTitle || title) { %><meta property="og:title" content="<%= meta.ogTitle || title %>" /><% } %>
      <% if (meta.ogDescription || meta.description) { %><meta property="og:description" content="<%= meta.ogDescription || meta.description %>" /><% } %>
      <% if (meta.ogType) { %><meta property="og:type" content="<%= meta.ogType %>" /><% } %>
      <% if (meta.ogUrl || meta.canonicalUrl) { %><meta property="og:url" content="<%= meta.ogUrl || meta.canonicalUrl %>" /><% } %>
      <% if (meta.ogImage) { %><meta property="og:image" content="<%= meta.ogImage %>" /><% } %>
      <% if (meta.twitterCard) { %><meta name="twitter:card" content="<%= meta.twitterCard %>" /><% } %>
      <% if (meta.ogTitle || title) { %><meta name="twitter:title" content="<%= meta.ogTitle || title %>" /><% } %>
      <% if (meta.ogDescription || meta.description) { %><meta name="twitter:description" content="<%= meta.ogDescription || meta.description %>" /><% } %>
      <% if (meta.ogImage) { %><meta name="twitter:image" content="<%= meta.ogImage %>" /><% } %>
    <% } %>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=Manrope:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body data-store-theme="<%= typeof storeThemeKey === 'string' && storeThemeKey ? storeThemeKey : 'cordoba' %>">
    <% const basePath = typeof storeBasePath === "string" ? storeBasePath : ""; %>
    <% const brandLabel = typeof storeName === "string" && storeName.trim() ? storeName : "Pre-loved by Lhota"; %>
    <% const visibleCategories = Array.isArray(storeAvailableCategories) ? storeAvailableCategories : ["Clothes", "Bags", "Trips", "Cars", "Miscellaneous"]; %>
    <header class="site-header">
      <div class="announcement-bar">
        <span class="announcement-arrow">&#8249;</span>
        <span>FREE STANDARD SHIPPING ON ALL ORDERS</span>
        <span class="announcement-arrow">&#8250;</span>
      </div>
      <div class="container nav-row">
        <a class="brand" href="<%= basePath || '/' %>" aria-label="<%= brandLabel %>">
          <img class="brand-logo" src="/assets/logo-preloved-lhota.svg" alt="Pre-loved by Lhota" />
        </a>
        <nav class="nav-links">
          <a class="main-nav-link" href="<%= basePath %>/shop">Shop</a>
          <a class="main-nav-link" href="<%= basePath %>/live-selling">Live Selling</a>
          <% if (visibleCategories.includes("Clothes")) { %><a class="main-nav-link" href="<%= basePath %>/shop/clothes">Clothes</a><% } %>
          <% if (visibleCategories.includes("Bags")) { %><a class="main-nav-link" href="<%= basePath %>/shop/bags">Bags</a><% } %>
          <% if (visibleCategories.includes("Trips")) { %><a class="main-nav-link" href="<%= basePath %>/shop/trips">Trips</a><% } %>
          <% if (visibleCategories.includes("Cars")) { %><a class="main-nav-link" href="<%= basePath %>/shop/cars">Cars</a><% } %>
          <% if (visibleCategories.includes("Miscellaneous")) { %><a class="main-nav-link" href="<%= basePath %>/shop/miscellaneous">Miscellaneous</a><% } %>
          <a class="main-nav-link" href="<%= basePath %>/cart">Cart</a>
        </nav>
        <div class="nav-icons">
          <a href="<%= basePath %>/shop" aria-label="Search">&#128269;</a>
          <% if (buyerUser) { %>
            <a href="/logout?<%= basePath ? `next=${encodeURIComponent(basePath || "/")}` : '' %>">Logout</a>
          <% } else { %>
            <a href="/login?<%= basePath ? `redirectTo=${encodeURIComponent(basePath || "/")}` : '' %>">Login</a>
            <a href="/signup?<%= basePath ? `redirectTo=${encodeURIComponent(basePath || "/")}` : '' %>">Sign Up</a>
          <% } %>
        </div>
      </div>
    </header>
    <main class="container page-content">
