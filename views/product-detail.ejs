<%- include('partials/header', { title: `${item.name} - ${storeName || "Pre-loved by Lhota"}`, meta, storeBasePath, storeName, storeCartKey, storeThemeKey }) %>

<section class="section-head product-detail-head">
  <p><a class="breadcrumb-link" href="<%= storeBasePath %>/shop">Shop</a> / <span><%= item.category %></span></p>
  <h1><%= item.name %></h1>
</section>

<% if (error) { %>
  <div class="alert alert-error"><%= error %></div>
<% } %>

<section class="product-detail-layout">
  <div class="product-detail-image">
    <img src="<%= item.imageUrl %>" alt="<%= item.name %>" />
  </div>

  <div class="card item-card-body product-main-body">
    <span class="item-category"><%= item.category %></span>
    <h2><%= item.name %></h2>
    <p class="item-description"><%= item.description %></p>
    <p class="stock-text"><%= item.stock %> pieces available</p>
    <p class="price"><%= formatCurrency(item.price) %></p>

    <div class="product-main-actions">
      <button class="button button-primary add-to-cart" data-item-id="<%= item.id %>" <%= item.stock < 1 ? "disabled" : "" %>>
        <%= item.stock < 1 ? "Out of Stock" : "Add to Cart" %>
      </button>
      <a class="button" href="<%= storeBasePath %>/cart">Go to Checkout</a>
      <% if (item.paymongoLink) { %>
        <a class="button button-secondary" href="<%= storeBasePath %>/payment/waiting/<%= encodeURIComponent(item.id) %>">Pay via PayMongo</a>
      <% } %>
    </div>
  </div>
</section>

<section class="catalog-section">
  <div class="section-head section-center">
    <h2>More In <%= item.category %></h2>
  </div>

  <% if (relatedItems.length === 0) { %>
    <div class="card">
      <p>No related items yet. <a href="<%= storeBasePath %>/shop">Browse all products</a>.</p>
    </div>
  <% } %>

  <div class="item-grid">
    <% relatedItems.forEach((relatedItem) => { %>
      <article class="item-card">
        <a class="item-image-link" href="<%= storeBasePath %>/product/<%= encodeURIComponent(relatedItem.id) %>">
          <img src="<%= relatedItem.imageUrl %>" alt="<%= relatedItem.name %>" />
        </a>
        <div class="item-card-body">
          <span class="item-category"><%= relatedItem.category %></span>
          <h3>
            <a class="item-title-link" href="<%= storeBasePath %>/product/<%= encodeURIComponent(relatedItem.id) %>"><%= relatedItem.name %></a>
          </h3>
          <p class="item-description"><%= relatedItem.description %></p>
          <p class="stock-text"><%= relatedItem.stock %> pieces available</p>
          <p class="price"><%= formatCurrency(relatedItem.price) %></p>
          <button class="button button-primary add-to-cart" data-item-id="<%= relatedItem.id %>" <%= relatedItem.stock < 1 ? "disabled" : "" %>>
            <%= relatedItem.stock < 1 ? "Out of Stock" : "Add to Cart" %>
          </button>
          <a class="button view-detail-btn" href="<%= storeBasePath %>/product/<%= encodeURIComponent(relatedItem.id) %>">View Details</a>
        </div>
      </article>
    <% }) %>
  </div>
</section>

<div id="cart-modal" class="cart-modal" aria-hidden="true">
  <div class="cart-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="cart-modal-title">
    <button id="cart-modal-close" class="cart-modal-close" type="button" aria-label="Close confirmation">x</button>
    <h3 id="cart-modal-title">Add to Cart</h3>
    <p id="cart-modal-message">How many pieces would you like to add?</p>
    <div class="cart-modal-pieces">
      <label for="cart-modal-pieces-input">Pieces</label>
      <input id="cart-modal-pieces-input" type="number" min="1" value="1" />
    </div>
    <div class="cart-modal-actions">
      <button id="cart-modal-cancel" class="button button-secondary" type="button">Cancel</button>
      <button id="cart-modal-confirm" class="button button-primary" type="button">Confirm Add</button>
    </div>
    <a class="button" href="<%= storeBasePath %>/cart">Go to Cart</a>
  </div>
</div>

<script>
  window.ITEM_CATALOG = <%- allItemsJson %>;
  window.STORE_BASE_PATH = <%- JSON.stringify(storeBasePath || "") %>;
  window.STORE_CART_KEY = <%- JSON.stringify(storeCartKey || "preloved_cart") %>;
</script>
<script src="/js/storefront.js"></script>

<%- include('partials/footer') %>
